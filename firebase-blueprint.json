{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and account information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin", "super_admin", "finance_admin", "support_admin"] },
        "availableBalance": { "type": "number" },
        "transferPin": { "type": "string" },
        "totalProfit": { "type": "number" },
        "totalWithdrawal": { "type": "number" },
        "totalDeposit": { "type": "number" },
        "referralCode": { "type": "string" },
        "referredBy": { "type": "string" },
        "isBanned": { "type": "boolean" },
        "isFrozen": { "type": "boolean" },
        "services": {
          "type": "object",
          "properties": {
            "investment": { "type": ["object", "null"] },
            "mentorship": { "type": ["object", "null"] },
            "signals": { "type": ["object", "null"] },
            "evaluation": { "type": ["object", "null"] },
            "accountManagement": { "type": ["object", "null"] }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Wallet": {
      "title": "Wallet",
      "description": "User financial wallet information",
      "type": "object",
      "properties": {
        "balance": { "type": "number" },
        "totalDeposit": { "type": "number" },
        "totalWithdraw": { "type": "number" },
        "totalProfit": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["balance", "totalDeposit", "totalWithdraw", "totalProfit"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Unified transaction ledger (Deposits, Withdrawals, Transfers, Profits)",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["deposit", "withdrawal", "transfer_in", "transfer_out", "profit", "referral_bonus"] },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "completed", "rejected"] },
        "method": { "type": "string" },
        "details": { "type": "object" },
        "proofUrl": { "type": "string" },
        "targetUserId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "amount", "status", "createdAt"]
    },
    "ServiceSubscription": {
      "title": "ServiceSubscription",
      "description": "User subscriptions for various services",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "serviceType": { "type": "string", "enum": ["mentorship", "signals", "investment", "account_management", "evaluation"] },
        "planId": { "type": "string" },
        "planName": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "active", "rejected", "expired", "completed"] },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "details": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "serviceType", "status", "createdAt"]
    },
    "AdminLog": {
      "title": "AdminLog",
      "description": "Audit logs for admin actions",
      "type": "object",
      "properties": {
        "adminId": { "type": "string" },
        "adminEmail": { "type": "string" },
        "action": { "type": "string" },
        "targetUserId": { "type": "string" },
        "details": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["adminId", "action", "timestamp"]
    },
    "Notification": {
      "title": "Notification",
      "description": "In-app notifications for users",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "success", "warning", "error"] },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "isRead", "createdAt"]
    },
    "SystemSettings": {
      "title": "SystemSettings",
      "description": "Global system configurations and feature toggles",
      "type": "object",
      "properties": {
        "roi": {
          "type": "object",
          "properties": {
            "bronze": { "type": "number" },
            "silver": { "type": "number" },
            "gold": { "type": "number" }
          }
        },
        "features": {
          "type": "object",
          "properties": {
            "depositsEnabled": { "type": "boolean" },
            "withdrawalsEnabled": { "type": "boolean" },
            "transfersEnabled": { "type": "boolean" },
            "mentorshipEnabled": { "type": "boolean" },
            "signalsEnabled": { "type": "boolean" },
            "investmentEnabled": { "type": "boolean" },
            "accountManagementEnabled": { "type": "boolean" },
            "evaluationEnabled": { "type": "boolean" }
          }
        },
        "prices": { "type": "object" },
        "durations": { "type": "object" },
        "updatedBy": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/wallets/{userId}": {
      "schema": "Wallet",
      "description": "User financial wallet documents"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Unified transaction ledger"
    },
    "/subscriptions/{subscriptionId}": {
      "schema": "ServiceSubscription",
      "description": "User service subscriptions"
    },
    "/adminLogs/{logId}": {
      "schema": "AdminLog",
      "description": "Admin activity logs"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    },
    "/settings/global": {
      "schema": "SystemSettings",
      "description": "Global system settings"
    }
  }
}
