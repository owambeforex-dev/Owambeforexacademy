{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and account information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "availableBalance": { "type": "number" },
        "transferPin": { "type": "string" },
        "totalProfit": { "type": "number" },
        "totalWithdrawal": { "type": "number" },
        "totalDeposit": { "type": "number" },
        "referralCode": { "type": "string" },
        "referredBy": { "type": "string" },
        "services": {
          "type": "object",
          "properties": {
            "investment": { "type": ["object", "null"] },
            "mentorship": { "type": ["object", "null"] },
            "signals": { "type": ["object", "null"] },
            "evaluation": { "type": ["object", "null"] },
            "accountManagement": { "type": ["object", "null"] }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Investment": {
      "title": "Investment",
      "description": "User investment records",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "planName": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "completed"] },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "planName", "amount", "status"]
    },
    "Deposit": {
      "title": "Deposit",
      "description": "User deposit requests",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "proofUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "status"]
    },
    "Withdrawal": {
      "title": "Withdrawal",
      "description": "User withdrawal requests",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "address": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "status"]
    },
    "AccountManagementApplication": {
      "title": "AccountManagementApplication",
      "description": "Applications for account management services",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "accountType": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email", "status"]
    },
    "ActivityLog": {
      "title": "ActivityLog",
      "description": "Logs of user activity",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "action", "timestamp"]
    },
    "Challenge": {
      "title": "Challenge",
      "description": "Prop firm challenge records",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "accountSize": { "type": "string" },
        "platform": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "active", "passed", "failed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "accountSize", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/investments/{investmentId}": {
      "schema": "Investment",
      "description": "Investment records"
    },
    "/deposits/{depositId}": {
      "schema": "Deposit",
      "description": "Deposit requests"
    },
    "/withdrawals/{withdrawalId}": {
      "schema": "Withdrawal",
      "description": "Withdrawal requests"
    },
    "/accountManagementApplications/{appId}": {
      "schema": "AccountManagementApplication",
      "description": "Account management applications"
    },
    "/activityLogs/{logId}": {
      "schema": "ActivityLog",
      "description": "User activity logs"
    },
    "/challenges/{challengeId}": {
      "schema": "Challenge",
      "description": "Prop firm challenge records"
    }
  }
}
